{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="card">
    <div class="card-header">
        <h3 class="card-header-title">{{ 'Connect to Newsman'|trans({}, 'Modules.Newsman.Admin') }}</h3>
    </div>
    <div class="card-body">
        <h4>{{ 'Features'|trans({}, 'Modules.Newsman.Admin') }}</h4>
        <ul class="list-unstyled">
            <li>&#10003; {{ 'Sync newsletter subscribers to Newsman'|trans({}, 'Modules.Newsman.Admin') }}</li>
            <li>&#10003; {{ 'Remarketing and tracking scripts'|trans({}, 'Modules.Newsman.Admin') }}</li>
            <li>&#10003; {{ 'Subscription forms and popups'|trans({}, 'Modules.Newsman.Admin') }}</li>
            <li>&#10003; {{ 'Email and SMS automation'|trans({}, 'Modules.Newsman.Admin') }}</li>
            <li>&#10003; {{ 'Product feed export'|trans({}, 'Modules.Newsman.Admin') }}</li>
            <li>&#10003; {{ 'Order tracking'|trans({}, 'Modules.Newsman.Admin') }}</li>
        </ul>
        <div class="mt-4">
            <a href="{{ oauthUrl }}" class="btn btn-primary btn-lg">
                {{ 'Connect with Newsman'|trans({}, 'Modules.Newsman.Admin') }}
            </a>
            {% if hasCredentials %}
            <a href="{{ path('newsman_configuration') }}" class="btn btn-outline-secondary ml-2 ms-2">
                {{ 'Cancel'|trans({}, 'Admin.Actions') }}
            </a>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
