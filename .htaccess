# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
    <FilesMatch "\.(?:css|js|png|gif|jpg|jpeg|svg|webp|woff2?)$">
        Allow from all
    </FilesMatch>
</IfModule>

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
    <FilesMatch "\.(?:css|js|png|gif|jpg|jpeg|svg|webp|woff2?)$">
        Require all granted
    </FilesMatch>
</IfModule>
